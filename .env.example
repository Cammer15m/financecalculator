# Copy to .env for docker compose.
POSTGRES_DB=financecalc
POSTGRES_USER=financecalc
POSTGRES_PASSWORD=change-me-long-random

# Must be at least 32 characters. Generate with: openssl rand -base64 48
SESSION_PASSWORD=replace-with-32-plus-char-random-string-____________________

# Optional: provisioned on first boot if no admin exists yet.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-at-first-login

# Host port the app is exposed on.
APP_PORT=3000
